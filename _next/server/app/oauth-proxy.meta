{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/oauth-proxy/layout,_N_T_/oauth-proxy/page,_N_T_/oauth-proxy"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/oauth-proxy/__PAGE__",
    "/oauth-proxy",
    "/_index",
    "/_head"
  ]
}