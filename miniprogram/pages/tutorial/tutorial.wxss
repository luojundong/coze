.tutorial-page {
  min-height: 100vh;
  background: #F9FAFB;
  padding-bottom: 40rpx;
}

.tutorial-header {
  background: linear-gradient(135deg, #4F46E5, #6366F1);
  padding: 48rpx 32rpx 40rpx;
  text-align: center;
  color: #FFFFFF;
}

.tutorial-header-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.tutorial-header-sub {
  font-size: 24rpx;
  opacity: 0.85;
}

.loading-area {
  text-align: center;
  padding: 120rpx 0;
  color: #6B7280;
  font-size: 26rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E5E7EB;
  border-top-color: #4F46E5;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.tutorial-list {
  padding: 24rpx 32rpx;
}

.tutorial-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tutorial-item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: #EEF2FF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tutorial-item-info {
  flex: 1;
  min-width: 0;
}

.tutorial-item-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 4rpx;
}

.tutorial-item-desc {
  display: block;
  font-size: 24rpx;
  color: #9CA3AF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tutorial-item-arrow {
  font-size: 36rpx;
  color: #D1D5DB;
  margin-left: 12rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9CA3AF;
}

/* ===== 教程详情弹窗 ===== */
.tutorial-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tutorial-modal {
  width: 86vw;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.tutorial-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #F3F4F6;
  flex-shrink: 0;
}

.tutorial-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
  flex: 1;
  margin-right: 20rpx;
}

.tutorial-modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #9CA3AF;
  background: #F3F4F6;
  border-radius: 50%;
  flex-shrink: 0;
}

.tutorial-modal-body {
  flex: 1;
  padding: 24rpx 40rpx 32rpx 32rpx;
  max-height: 50vh;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
}

.tutorial-detail-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.8;
}

.tutorial-detail-link {
  font-size: 28rpx;
  color: #2563EB;
  line-height: 1.8;
  text-decoration: underline;
  word-break: break-all;
}

.tutorial-detail-br {
  height: 12rpx;
}

.tutorial-detail-image {
  display: block;
  width: 100%;
  margin: 16rpx 0;
  border-radius: 12rpx;
  background: #F3F4F6;
}

.tutorial-detail-video {
  display: block;
  width: 100%;
  margin: 16rpx 0;
  border-radius: 12rpx;
  background: #000;
}
