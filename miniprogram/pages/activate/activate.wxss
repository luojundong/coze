.activate-page {
  padding-top: 80rpx;
}

/* Logo 区域（参考登录页） */
.logo-area {
  text-align: center;
  margin-bottom: 64rpx;
}

.logo-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: #2563EB;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.logo-text {
  font-size: 50rpx;
}

.app-name {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.app-desc {
  display: block;
  font-size: 26rpx;
  color: #6B7280;
}

/* 表单区域（参考登录页） */
.form-area {
  margin-top: 32rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 12rpx;
}

/* 激活码输入框（参考登录页 .input-login，加宽加大） */
.input-activate {
  padding: 24rpx;
  font-size: 32rpx;
  height: auto;
  line-height: 1.5;
  letter-spacing: 2rpx;
}

.error-msg {
  background: #FEF2F2;
  color: #991B1B;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

/* 成功状态 */
.success-area {
  text-align: center;
  margin-bottom: 64rpx;
}

.success-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
}

.success-desc {
  display: block;
  font-size: 28rpx;
  color: #6B7280;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #D1FAE5;
  color: #065F46;
  font-size: 60rpx;
  line-height: 120rpx;
  text-align: center;
  margin: 0 auto 24rpx;
}
