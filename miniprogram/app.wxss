/**app.wxss**/
page {
  background-color: #F9FAFB;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 32rpx;
}

/* 通用卡片 */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 主色按钮 */
.btn-primary {
  background-color: #2563EB;
  color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background-color: #93C5FD;
  color: #FFFFFF;
}

/* 次要按钮 */
.btn-secondary {
  background-color: #FFFFFF;
  color: #2563EB;
  border-radius: 12rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  border: 2rpx solid #2563EB;
}

.btn-secondary::after {
  border: none;
}

/* 危险按钮 */
.btn-danger {
  background-color: #EF4444;
  color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

/* 输入框 */
.input {
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

.input:focus {
  border-color: #2563EB;
}

/* 标签 */
.badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-success {
  background-color: #D1FAE5;
  color: #065F46;
}

.badge-warning {
  background-color: #FEF3C7;
  color: #92400E;
}

.badge-danger {
  background-color: #FEE2E2;
  color: #991B1B;
}

/* 标题 */
.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 24rpx;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background-color: #E5E7EB;
  margin: 24rpx 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #6B7280;
}

.empty-state .empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-state .empty-text {
  font-size: 30rpx;
}
